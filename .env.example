# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# These variables are consumed by scripts/ and configs/paths.yaml.

# ---- Hugging Face ----
# Token with access to the gated CONCH / Virchow2 / SEAL / HEST repos.
# Create one at https://huggingface.co/settings/tokens (read scope is enough).
HF_TOKEN=

# Some tools read alternate names; keep them in sync with HF_TOKEN if needed.
# HUGGINGFACE_HUB_TOKEN=
# HF_API_KEY=

# ---- Data / output roots ----
# Root where HEST-bench data (patches, h5ad, splits, gene lists) will be downloaded.
DATA_DIR=/path/to/data

# Root where benchmark outputs (embeddings + prediction results) are written.
RESULTS_DIR=/path/to/results

# Optional: where the raw WSIs live (only needed for the Trident extraction demo).
WSI_DIR=/path/to/wsis
